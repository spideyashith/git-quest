{
  "name": "git-quest",
  "displayName": "Git Quest",
  "description": "A visual and gamified Git learning experience inside VS Code.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "git-quest",
          "title": "Git Quest",
          "icon": "media/git-quest.svg"
        }
      ]
    },
    "views": {
      "git-quest": [
        {
          "id": "git-quest-view",
          "name": "Git Quest"
        }
      ]
    },
    "commands": [
      { "command": "git-quest.openRepository", "title": "Open Repository" },
      { "command": "git-quest.openCurrentQuest", "title": "Open Current Quest" },
      { "command": "git-quest.openAchievements", "title": "Open Achievements" },
      { "command": "git-quest.stageFile", "title": "Stage File" },
      { "command": "git-quest.unstageFile", "title": "Unstage File" },
      { "command": "git-quest.commit", "title": "Commit" }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "git-quest.stageFile",
          "when": "view == git-quest-view && viewItem == modifiedFile",
          "group": "1_modification"
        },
        {
          "command": "git-quest.unstageFile",
          "when": "view == git-quest-view && viewItem == stagedFile",
          "group": "1_modification"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
